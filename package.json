{
    "name": "evolab-ga-learning-demo",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "concurrently -k -n api,web -c yellow,cyan \"tsx watch server/index.ts\" \"vite\"",
        "build": "tsc -b && vite build && tsc -p tsconfig.server.json",
        "start": "node dist-server/index.js",
        "lint": "eslint .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "format": "prettier --write ."
    },
    "dependencies": {
        "@heroui/react": "^3.0.0",
        "@heroui/styles": "^3.0.0",
        "brain.js": "2.0.0-beta.24",
        "express": "^5.1.0",
        "lucide-react": "^0.468.0",
        "matter-js": "^0.20.0",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "recharts": "^3.0.0",
        "tailwind-variants": "^3.1.0",
        "yahoo-finance2": "^4.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.30.0",
        "@playwright/test": "^1.53.0",
        "@tailwindcss/vite": "^4.1.0",
        "@testing-library/jest-dom": "^6.6.0",
        "@testing-library/react": "^16.3.0",
        "@types/express": "^5.0.0",
        "@types/matter-js": "^0.19.8",
        "@types/node": "^24.0.0",
        "@types/react": "^19.1.0",
        "@types/react-dom": "^19.1.0",
        "@vitejs/plugin-react": "^4.6.0",
        "concurrently": "^9.2.0",
        "eslint": "^9.30.0",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.20",
        "globals": "^16.2.0",
        "jsdom": "^26.1.0",
        "tailwindcss": "^4.1.0",
        "tsx": "^4.20.0",
        "typescript": "~5.8.3",
        "typescript-eslint": "^8.35.0",
        "prettier": "3.9.5",
        "prettier-plugin-tailwindcss": "0.8.0",
        "vite": "^7.0.0",
        "vitest": "^3.2.0"
    }
